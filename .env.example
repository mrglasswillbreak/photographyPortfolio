# Admin credentials
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-secure-password

# JWT secret for session tokens (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-here

# Vercel Postgres / Neon (auto-populated when you add a database in Vercel)
# New Neon native integration uses DATABASE_URL:
DATABASE_URL=
DATABASE_URL_UNPOOLED=
# Legacy Vercel Postgres uses POSTGRES_URL (kept for backwards compatibility):
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Vercel Blob (auto-populated when you add Blob storage in Vercel)
BLOB_READ_WRITE_TOKEN=

# Email (Gmail SMTP via Nodemailer)
# Your Gmail address used to send contact form emails
GMAIL_USER=your-gmail@gmail.com
# Gmail App Password (NOT your Gmail login password).
# Generate one at: Google Account → Security → 2-Step Verification → App Passwords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# Email address to receive contact form submissions (can be any email address)
CONTACT_EMAIL=your@email.com
