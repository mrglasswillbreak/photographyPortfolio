# Admin credentials
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-secure-password

# JWT secret for session tokens (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-here

# Vercel Postgres / Neon (auto-populated when you add a database in Vercel)
# New Neon native integration uses DATABASE_URL:
DATABASE_URL=
DATABASE_URL_UNPOOLED=
# Legacy Vercel Postgres uses POSTGRES_URL (kept for backwards compatibility):
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Vercel Blob (auto-populated when you add Blob storage in Vercel)
BLOB_READ_WRITE_TOKEN=

# Email (Resend - get your API key at resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
# Email address to receive contact form submissions
CONTACT_EMAIL=your@email.com
# Sender address shown in contact-form emails.
# Must use a domain verified in your Resend account for reliable delivery.
# Defaults to Resend's shared test address (onboarding@resend.dev) if not set,
# which only delivers to the email registered with your Resend account.
FROM_EMAIL=Portfolio Contact <your-verified-sender@yourdomain.com>
